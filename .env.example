# imap-to-webhook — cp .env.example .env, then fill in your values.

# ============================================================================
# Required
# ============================================================================

# IMAP connection URL
#
# Format:
#   imap+ssl://USERNAME:PASSWORD@HOST:PORT/?inbox=FOLDER&error=FOLDER&success=FOLDER&refused=FOLDER
#
# Scheme:
#   imap+ssl  — IMAP over TLS (port 993, recommended)
#   imap      — plain IMAP (port 143)
#
# Credentials:
#   @ in username works as-is — urlparse splits at the LAST @, no encoding needed.
#   Special chars in password must be percent-encoded (e.g. p@ss!  ->  p%40ss%21).
#
# Query params (all optional, control IMAP folder names):
#   inbox    — folder to poll for new messages              [default: INBOX]
#   success  — destination after successful webhook delivery [default: SUCCESS]
#   error    — destination when processing fails             [default: ERROR]
#   refused  — destination when webhook responds REFUSED     [default: REFUSED]
#
# Full example:
#   imap+ssl://sales@kingsing.com:p%40ssw0rd@imap.exmail.qq.com:993/?inbox=INBOX&success=Processed&error=Failed&refused=Rejected
#
IMAP_URL_1=imap+ssl://user@example.com:password@imap.example.com:993/?inbox=INBOX&success=SUCCESS&error=ERROR&refused=REFUSED

# Multi-account: add IMAP_URL_2, IMAP_URL_3, ... (all share the same WEBHOOK_URL)
# IMAP_URL_2=imap+ssl://support@example.com:pass2@imap.example.com:993/

# Webhook endpoint — receives parsed emails as multipart/form-data POST
WEBHOOK_URL=https://example.com/webhook

# ============================================================================
# Processing
# ============================================================================

# Action after successful webhook delivery: move | delete | noop  [default: move]
#   move   — move email to the "success" folder
#   delete — permanently delete from inbox
#   noop   — leave in inbox, mark with NOOP_FLAG to skip next poll
ON_SUCCESS=move

# IMAP flag used in noop mode to mark processed emails  [default: \Seen]
# \Seen works but conflicts with mail clients marking emails as read.
# For dedicated mailboxes use \Seen; for shared mailboxes set a custom keyword
# (e.g. $WebhookProcessed). Custom keywords require PERMANENTFLAGS to include \*.
# NOOP_FLAG=\Seen

# Gzip-compress the raw .eml attachment before POST  [default: false]
COMPRESS_EML=false

# Seconds to wait between poll cycles when all inboxes are empty  [default: 60]
DELAY=60

# IMAP socket timeout in seconds  [default: 60]
# IMAP_TIMEOUT=60

# Max emails to download per IMAP session  [default: 1]
# Higher values reduce IMAP round-trips but increase memory usage.
# BATCH_SIZE=1

# Seconds to pause between webhook deliveries within a batch  [default: 0]
# Useful for rate-limiting to avoid overwhelming the webhook endpoint.
# DELIVERY_INTERVAL=0

# Processing order: fifo (oldest first) | lifo (newest first)  [default: fifo]
# PROCESS_ORDER=fifo

# ============================================================================
# Webhook
# ============================================================================

# Sent as X-Webhook-Secret header on every POST  [default: empty]
# Use this to authenticate requests on the webhook side.
# WEBHOOK_SECRET=

# Max retries on 5xx / connection error  [default: 0 = no retry]
# 4xx errors are never retried (treated as permanent rejection).
# WEBHOOK_MAX_RETRIES=0

# Exponential backoff base delay in seconds  [default: 10]
# Actual delay: base * 2^(attempt-1), e.g. 10s, 20s, 40s, ...
# WEBHOOK_RETRY_DELAY=10

# ============================================================================
# Monitoring
# ============================================================================

# Sentry DSN for error tracking  [default: disabled]
# SENTRY_DSN=

# Docker HEALTHCHECK heartbeat file  [default: /tmp/imap-to-webhook-heartbeat]
# Daemon touches this file after each successful poll cycle.
# HEARTBEAT_FILE=/tmp/imap-to-webhook-heartbeat

# Max heartbeat age in seconds before container is marked UNHEALTHY  [default: 600]
# HEARTBEAT_MAX_AGE=600

# Interval between stats summary log lines, in seconds  [default: 300]
# STATS_LOG_INTERVAL=300
