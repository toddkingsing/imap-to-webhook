# imap-to-webhook — cp .env.example .env, then fill in your values.

# --- Required ---

# IMAP connection URL (@ in username works as-is, parser splits at the last @)
# Query params: inbox, error, success, refused (defaults: INBOX, ERROR, SUCCESS, REFUSED)
IMAP_URL_1=imap+ssl://user@example.com:password@imap.example.com:993/

# Add more accounts: IMAP_URL_2, IMAP_URL_3, ...
# IMAP_URL_2=imap+ssl://support@example.com:pass2@imap.example.com:993/

# Webhook endpoint (receives multipart/form-data POST)
WEBHOOK_URL=https://example.com/webhook

# --- Processing ---

# After successful delivery: move | delete | noop [default: move]
ON_SUCCESS=move

# IMAP flag for noop mode tracking [default: \Seen]
# Set to a custom keyword (e.g. $WebhookProcessed) to decouple from mail client read status.
# Requires server PERMANENTFLAGS to include \*.
# NOOP_FLAG=\Seen

# Gzip-compress the raw .eml attachment [default: false]
COMPRESS_EML=false

# Poll interval when inbox is empty, in seconds [default: 60]
DELAY=60

# IMAP socket timeout in seconds [default: 60]
# IMAP_TIMEOUT=60

# Emails to download per IMAP session [default: 1]
# BATCH_SIZE=1

# Pause between webhook deliveries within a batch, in seconds [default: 0]
# DELIVERY_INTERVAL=0

# Processing order: fifo (oldest first) | lifo (newest first) [default: fifo]
# PROCESS_ORDER=fifo

# --- Webhook ---

# X-Webhook-Secret header value [default: empty]
# WEBHOOK_SECRET=

# Retry on 5xx / connection error [default: 0 = no retry]
# WEBHOOK_MAX_RETRIES=0

# Exponential backoff base delay in seconds [default: 10]
# WEBHOOK_RETRY_DELAY=10

# --- Monitoring ---

# Sentry DSN [default: disabled]
# SENTRY_DSN=

# Docker HEALTHCHECK heartbeat file [default: /tmp/imap-to-webhook-heartbeat]
# HEARTBEAT_FILE=/tmp/imap-to-webhook-heartbeat

# Max heartbeat age before UNHEALTHY, in seconds [default: 600]
# HEARTBEAT_MAX_AGE=600

# Stats log interval in seconds [default: 300]
# STATS_LOG_INTERVAL=300
