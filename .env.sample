# =============================================================================
# imap-to-webhook environment configuration
# Copy this file and fill in your values:
#   cp .env.sample env/aggregator.env
# =============================================================================

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# IMAP connection URL
# Format: imap+ssl://user@domain.com:password@imap.host:993/?inbox=INBOX&error=ERROR&success=SUCCESS&refused=REFUSED
# The parser splits at the LAST @ to separate credentials from host, so @ in the username works as-is.
#   inbox   = folder to poll (default: INBOX)
#   error   = folder for failed messages (default: ERROR)
#   success = folder for delivered messages (default: SUCCESS)
#   refused = folder for webhook-refused messages (default: REFUSED)
IMAP_URL=imap+ssl://user@example.com:password@imap.example.com:993/?inbox=INBOX&error=ERROR&success=SUCCESS&refused=REFUSED

# Multi-account: use IMAP_URL_1, IMAP_URL_2, ... instead of IMAP_URL.
# When numbered URLs are present, IMAP_URL is ignored.
# IMAP_URL_1=imap+ssl://sales@example.com:pass1@imap.example.com:993/
# IMAP_URL_2=imap+ssl://support@example.com:pass2@imap.example.com:993/

# Webhook endpoint to receive parsed email data (multipart/form-data POST)
WEBHOOK_URL=https://example.com/webhook

# ---------------------------------------------------------------------------
# Processing behavior
# ---------------------------------------------------------------------------

# Action after successful webhook delivery (default: move)
#   move   = move to success folder
#   delete = permanently delete
#   noop   = mark as read, leave in inbox
ON_SUCCESS=move

# Compress .eml attachment with gzip: "true" or "false" (default: false)
COMPRESS_EML=false

# Polling interval in seconds when inbox is empty (default: 60)
DELAY=60

# IMAP socket timeout in seconds (default: 60)
# IMAP_TIMEOUT=60

# Number of emails to download per IMAP session (default: 1)
# BATCH_SIZE=1

# Seconds to wait between webhook deliveries within a batch (default: 0)
# DELIVERY_INTERVAL=0

# Processing order: "fifo" (oldest first) or "lifo" (newest first) (default: fifo)
# PROCESS_ORDER=fifo

# ---------------------------------------------------------------------------
# Webhook delivery
# ---------------------------------------------------------------------------

# Value sent in X-Webhook-Secret header (default: empty)
# WEBHOOK_SECRET=

# Max retry attempts on 5xx or connection error (default: 0 = no retry)
# WEBHOOK_MAX_RETRIES=0

# Base delay in seconds for exponential backoff retries (default: 10)
# WEBHOOK_RETRY_DELAY=10

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------

# Sentry DSN for error tracking (default: disabled)
# SENTRY_DSN=https://key@sentry.io/project

# Heartbeat file path for Docker HEALTHCHECK (default: /tmp/imap-to-webhook-heartbeat)
# HEARTBEAT_FILE=/tmp/imap-to-webhook-heartbeat

# Max heartbeat file age in seconds before UNHEALTHY (default: 600)
# HEARTBEAT_MAX_AGE=600

# Interval in seconds between stats log output (default: 300)
# STATS_LOG_INTERVAL=300
